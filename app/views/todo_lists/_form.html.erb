<%= form_with model: @todo_list do |f| %>
  <% if @todo_list.errors.any? %>
    <div style= "color: red">
      <ul>
        <% @todo_list.errors.full_messages.each do |error| %>
          <li> <%= error %> </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name %> <br>
    <%= f.text_field :name, style: "width: 300px"%>
  </div>

  <div style = "margin-top:8px">
    <%= f.label :description %> <br>
    <%= f.text_area :description, style: "width: 300px"%>
  </div>

  <div style = "margin-top:8px">
    <%= f.submit %> <br>
  </div>
<% end %>